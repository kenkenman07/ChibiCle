# All settings use the BTD_ prefix.

# CORS — comma-separated origins allowed to call this API.
# In production, set to the frontend's deployed URL.
BTD_CORS_ORIGINS=["https://localhost:5173"]

# YOLO model file path (downloaded automatically on first run)
BTD_YOLO_MODEL=yolov8n.pt
BTD_YOLO_CONFIDENCE=0.4

# Violation detection thresholds
BTD_RED_SIGNAL_SPEED_THRESHOLD=3.0
BTD_RED_SIGNAL_MIN_BBOX_RATIO=0.003
BTD_RED_SIGNAL_PROXIMITY_M=25.0
BTD_STOP_SIGN_RADIUS_M=10.0
BTD_STOP_SIGN_SPEED_THRESHOLD=1.5
BTD_VIOLATION_COOLDOWN_S=120.0

# Overpass API cache
BTD_OVERPASS_CACHE_TTL_SECONDS=86400
BTD_OVERPASS_QUERY_RADIUS_M=500.0

# WebSocket heartbeat
BTD_WS_HEARTBEAT_INTERVAL=30.0
BTD_WS_HEARTBEAT_TIMEOUT=5.0
